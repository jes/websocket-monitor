{
  "manifest_version": 2,
  "name": "WebSocket Capture Monitor",
  "version": "0.1.0",
  "description": "Capture WebSocket traffic on demand and export it to JSON.",
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "WebSocket Capture Monitor",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "websocket-capture-monitor@example.local"
    }
  }
}
